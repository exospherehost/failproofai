{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "bash": "bun bin/failproofai.mjs --hook SessionStart --cli copilot",
            "powershell": "bun bin/failproofai.mjs --hook SessionStart --cli copilot",
            "timeoutSec": 60,
            "__failproofai_hook__": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "bash": "bun bin/failproofai.mjs --hook SessionEnd --cli copilot",
            "powershell": "bun bin/failproofai.mjs --hook SessionEnd --cli copilot",
            "timeoutSec": 60,
            "__failproofai_hook__": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
